# App
APP_NAME=Diploma AI Assistant API
APP_VERSION=3.5.0
APP_ENV=dev

# OpenAI direct
OPENAI_API_KEY=
OPENAI_BASE_URL=

# OpenRouter / OpenAI-compatible API
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LLM
OPENAI_MODEL=openrouter/free
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3

# Cache
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=300

# CORS
CORS_ORIGINS=["*"]

# Proxy, optional. Fill only in local .env, never commit real credentials.
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,redis,app
