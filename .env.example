# App
APP_NAME=Diploma AI Assistant API
APP_VERSION=3.4.0
APP_ENV=dev

# OpenAI direct
OPENAI_API_KEY=
OPENAI_BASE_URL=

# OpenRouter / OpenAI-compatible API
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LLM
OPENAI_MODEL=openrouter/free
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3

# Cache
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# CORS
# Для учебного проекта оставляем "*"
CORS_ORIGINS=["*"]