{
  "rest": {
    "RestGenerator": {
      "name": "diploma-fastapi-chat",
      "uri": "http://127.0.0.1:8000/chat",
      "method": "post",
      "headers": {
        "Content-Type": "application/json"
      },
      "req_template_json_object": {
        "messages": [
          {
            "role": "user",
            "content": "$INPUT"
          }
        ],
        "temperature": 0,
        "max_tokens": 120
      },
      "response_json": true,
      "response_json_field": "content",
      "request_timeout": 90
    }
  }
}